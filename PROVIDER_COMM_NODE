<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#050505] p-4">
    <div class="glass-panel p-4 rounded-2xl border border-zinc-800">
        <textarea id="msg-input" class="w-full bg-black border border-zinc-700 rounded-xl p-3 text-white text-sm mb-2" placeholder="Send instruction..."></textarea>
        <button onclick="send()" id="send-btn" class="w-full bg-blue-600 text-white font-black py-3 rounded-xl uppercase text-[10px]">Transmit to Patient</button>
    </div>

    <script>
        async function send() {
            const val = document.getElementById('msg-input').value;
            const btn = document.getElementById('send-btn');
            if(!val) return;

            btn.innerText = "SENDING...";
            try {
                await fetch('/api/pusher-relay', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: val, channel_id: "test-channel" })
                });
                btn.innerText = "SUCCESS ✅";
                document.getElementById('msg-input').value = "";
            } catch (e) {
                btn.innerText = "ERROR ❌";
            }
            setTimeout(() => { btn.innerText = "Transmit to Patient"; }, 2000);
        }
    </script>
</body>
</html>
